<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" prefHeight="429.0" prefWidth="601.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.hit.client.HelloController">
   <children>
      <TabPane layoutY="3.0" prefHeight="508.0" prefWidth="601.0" tabClosingPolicy="UNAVAILABLE">
        <tabs>
          <Tab text="Search &amp; Compare">
            <content>
              <AnchorPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="0.0" minWidth="0.0" prefHeight="382.0" prefWidth="601.0">
                     <children>
                        <ImageView fitHeight="400.0" fitWidth="600.0" pickOnBounds="true">
                           <image>
                              <Image url="@balygames.png" />
                           </image>
                        </ImageView>
                        <VBox alignment="CENTER" layoutX="-5.0" layoutY="20.0" prefHeight="379.0" prefWidth="602.0" spacing="20.0">
                           <children>
                              <ComboBox fx:id="gamesComboBox" cache="true" prefHeight="28.0" prefWidth="246.0">
                                 <VBox.margin>
                                    <Insets top="50.0" />
                                 </VBox.margin>
                              </ComboBox>
                              <Button mnemonicParsing="false" onAction="#onRefreshClick" prefHeight="27.0" prefWidth="86.0" text="Refresh List" />
                              <Button mnemonicParsing="false" onAction="#onSearchClick" prefHeight="33.0" prefWidth="130.0" text="Find Best Price">
                                 <font>
                                    <Font name="Berlin Sans FB Demi Bold" size="12.0" />
                                 </font>
                              </Button>
                              <Label fx:id="priceResultLabel" />
                           </children>
                        </VBox>
                     </children>
                  </AnchorPane>
            </content>
          </Tab>
            <Tab text="Full Price List">
                <content>
                    <AnchorPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                        <children>
                            <VBox alignment="CENTER_LEFT" prefHeight="370.0" prefWidth="600.0" spacing="10.0">
                                <padding>
                                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                </padding>
                                <children>
                                    <Label alignment="CENTER" text="Complete Games &amp; Prices Inventory">
                                        <font>
                                            <Font name="System Bold" size="16.0" />
                                        </font>
                                 <VBox.margin>
                                    <Insets left="150.0" />
                                 </VBox.margin>
                                    </Label>
                              <HBox prefHeight="297.0" prefWidth="579.0">
                                 <children>
                                          <TextArea fx:id="fullInventoryArea" editable="false" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="279.0" prefWidth="297.0" HBox.hgrow="ALWAYS" />
                                    <ImageView fitHeight="288.0" fitWidth="282.0" pickOnBounds="true" preserveRatio="true">
                                       <image>
                                          <Image url="@appimage.png" />
                                       </image>
                                    </ImageView>
                                 </children>
                              </HBox>
                                    <Button maxHeight="-Infinity" minHeight="-Infinity" mnemonicParsing="false" onAction="#onRefreshInventory" text="Update Full List">
                                 <VBox.margin>
                                    <Insets left="95.0" />
                                 </VBox.margin>
                              </Button>
                                </children>
                            </VBox>
                        </children>
                    </AnchorPane>
                </content>
            </Tab>
        </tabs>
      </TabPane>
   </children>
</AnchorPane>
